---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'MarketX - Make InfoBusiness Great Again', description = 'Sistemi di lancio milionari per infoprenditori. Agenzia specializzata in lanci infobusiness ad alto ticket.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  ::-webkit-scrollbar {
    width: 12px;
  }

  ::-webkit-scrollbar-track {
    background: #f5f5f5;
  }

  ::-webkit-scrollbar-thumb {
    background: #00d294;
    border-radius: 6px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: #00c758;
  }
</style>
