---

<section class="hero-gradient min-h-screen flex items-center justify-center py-20">
  <div class="container-custom text-center text-white space-y-8">
    <div class="space-y-6">
      <h1 class="text-5xl md:text-7xl font-display font-bold leading-tight">
        Make InfoBusiness <span class="text-primary-500">Great Again</span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
        Sistemi di lancio milionari ingegnerizzati per infoprenditori che meritano di crescere in modo prevedibile e replicabile.
      </p>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 justify-center pt-8">
      <button class="btn-primary">
        Scopri i Nostri Servizi
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </button>
      <button class="btn-outline">
        Scarica il Codex10™
      </button>
    </div>

    <div class="pt-12 grid grid-cols-3 gap-8 text-center">
      <div>
        <div class="text-3xl md:text-4xl font-bold text-primary-500">60+</div>
        <p class="text-gray-400">Clienti Trasformati</p>
      </div>
      <div>
        <div class="text-3xl md:text-4xl font-bold text-primary-500">€10M+</div>
        <p class="text-gray-400">Fatturato Gestito</p>
      </div>
      <div>
        <div class="text-3xl md:text-4xl font-bold text-primary-500">24.78x</div>
        <p class="text-gray-400">MER Massimo</p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-gradient {
    background: linear-gradient(135deg, #0A0A0A 0%, #0c0c0c 50%, #007956 100%);
    position: relative;
    overflow: hidden;
  }

  .hero-gradient::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(0, 210, 148, 0.1) 0%, transparent 70%);
    border-radius: 50%;
  }
</style>
